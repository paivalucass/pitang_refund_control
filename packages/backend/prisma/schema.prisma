generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  EMPLOYEE
  MANAGER
  FINANCE
  ADMIN
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  CANCELED
}

enum HistoryAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  CANCELED
}

enum AttachmentType {
  PDF
  JPG
  PNG
}

model User {
  id             String           @id @default(uuid()) @db.Uuid
  name           String
  email          String           @unique
  passwordHash   String
  role           UserRole
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  reimbursements Reimbursement[]  @relation("RequesterRequests")
  historyEntries RequestHistory[] @relation("UserHistoryEntries")

  @@map("users")
}

model Category {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @unique
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reimbursements Reimbursement[]

  @@map("categories")
}

model Reimbursement {
  id              String           @id @default(uuid()) @db.Uuid
  requesterId     String           @db.Uuid
  categoryId      String           @db.Uuid
  description     String
  amount          Decimal          @db.Decimal(12, 2)
  expenseDate     DateTime
  status          RequestStatus    @default(DRAFT)
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  requester       User             @relation("RequesterRequests", fields: [requesterId], references: [id], onDelete: Restrict)
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  attachments     Attachment[]
  history         RequestHistory[]

  @@index([requesterId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@map("refund_requests")
}

model Attachment {
  id            String         @id @default(uuid()) @db.Uuid
  requestId     String         @db.Uuid
  fileName      String
  fileUrl       String
  fileType      AttachmentType
  createdAt     DateTime       @default(now())
  reimbursement Reimbursement  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("attachments")
}

model RequestHistory {
  id            String        @id @default(uuid()) @db.Uuid
  requestId     String        @db.Uuid
  userId        String        @db.Uuid
  action        HistoryAction
  note          String?
  createdAt     DateTime      @default(now())
  reimbursement Reimbursement @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user          User          @relation("UserHistoryEntries", fields: [userId], references: [id], onDelete: Restrict)

  @@index([requestId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("request_history")
}
